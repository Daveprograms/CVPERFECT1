# Copy this file to ".env" and replace every placeholder. Never commit ".env".
#
# After setting DATABASE_URL, apply schema from the backend folder:
#   python -m alembic upgrade head
# See MIGRATIONS.md

# --- Supabase Postgres ---
# Dashboard → Project Settings → Database → Connection string → URI (Session pooler recommended).
# Username is usually: postgres.<PROJECT_REF>
# URL-encode special characters in the password (@ → %40, # → %23).
#
# If you see: FATAL (ENOTFOUND) tenant/user postgres.<ref> not found
# — the project ref, password, or pooler hostname is wrong, or the project was paused/deleted.
# Copy a fresh URI from Supabase; do not reuse an old example line.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@YOUR_POOLER_HOST.supabase.com:6543/postgres?sslmode=require

# Supabase project (REST/storage when wired in code)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Gemini — required for LLM features (resume analysis, chat, etc.)
GEMINI_API_KEY=

STRIPE_SECRET_KEY=

JWT_SECRET=your_long_random_secret

FRONTEND_URL=http://localhost:3000
